# $defs/chapter — a document node: an OMNI node with optional title/description and a
# positional body. The body is a plain sequence of unkeyed elements, read top to bottom;
# each element is EITHER a nested chapter (the recursion) OR a chunk (a renderable block).
#
# There is no `chunks` array and no `children` array — prose, media, diagrams, and
# subchapters are siblings in ONE ordered stream. Attach it to a yamlover node with the
# tag  !!<*yamlover/$defs/chapter>.  Spec: ../CHAPTER.md, ../META.md.
#
# `type: variant` is the omni node: keyed fields (title/description) AND positional
# elements (the body) at once. The body element type is a union — a chapter OR a chunk;
# the two are told apart structurally (a chapter is a container, a chunk is a leaf).
# NOTE: `properties` (keyed) + `items` (ordinal) is the JSON-Schema encoding of an omni
# node's two facets; META.md §Vocabulary proposes a native `elements`/`additionalElements`.
type: variant
properties:
  title:
    type: string
    format: text/marklower
  description:                     # optional subtitle / heading annotation
    type: string
    format: text/marklower
items:                             # the body — a positional sequence, read top to bottom
  anyOf:
    - *:: yamlover: $defs: chapter   # a nested subchapter (the recursion) — a container
    - *:: yamlover: $defs: table     # a table — enters only by its EXPLICIT tag (MARKLOWER.md)
    - *:: yamlover: $defs: bullets   # a bullet list — enters only by its explicit tag
    - *:: yamlover: $defs: numbered  # a numbered list — enters only by its explicit tag
    - *:: yamlover: $defs: chunk     # a content block — a leaf
