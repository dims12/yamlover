# $defs/annotation — ONE TAG APPLICATION: a region of a material (or the whole material) tagged
# by exactly one tag, saved as its own object and reverse-linked to the material. `target` is a
# project-scoped pointer (//…) at the annotated material; the engine derives the material's
# annotations as the inverse of these edges. The applied TAG is a keyless reverse membership —
# `~- *//path/to/tag` — so the annotation is a member of its tag like any tagged node; two tags
# on the same region = two annotation nodes. `selector` (optional — absent applies the tag to the
# WHOLE node) locates the segment WITHIN the material — its `type` says how: a text quote
# {type:text, exact, prefix, suffix}, an image/pdf rect {type:rect|pdf, x,y,w,h (pdf adds page)},
# a map region {type:map, n,s,e,w (geographic edges)}. The display color always comes from the
# applied tag (its `color`, else its name-derived hue) — never from the selector. `description`
# is an optional per-application comment. Attach with the tag !!<*yamlover/$defs/annotation>.
type: object
format: x-yamlover-annotation
properties:
  target:
    type: string
    description: A project-scoped pointer (//…) to the annotated material
  selector:
    type: object
    description: How to find the segment within the material; absent = the whole node
  description:
    type: string
    format: text/marklower
  created:
    type: string
