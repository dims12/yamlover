<Window x:Class="OneNote2Yamlover.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:OneNote2Yamlover.ViewModels"
        mc:Ignorable="d"
        Title="OneNote → yamlover"
        Height="660" Width="1060" MinHeight="420" MinWidth="720"
        ResizeMode="CanResizeWithGrip" SizeToContent="Manual"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- The tri-state checkbox IS the multi-select: WPF's TreeView has no built-in one. -->
        <HierarchicalDataTemplate DataType="{x:Type vm:TreeNodeVm}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <CheckBox IsThreeState="True" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          Checked="OnNodeChecked" Unchecked="OnNodeChecked" Indeterminate="OnNodeChecked" />
                <TextBlock Text="{Binding Glyph}" Margin="4,0,4,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
            </StackPanel>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate DataType="{x:Type vm:RemoteDirVm}" ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Name}" ToolTip="{Binding Path}" />
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="120" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition x:Name="LogRow" Height="120" MinHeight="0" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftColumn" Width="*" MinWidth="220" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition x:Name="RightColumn" Width="*" MinWidth="260" />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,6">
            <Button DockPanel.Dock="Right" Content="Reload" Padding="10,3"
                    Command="{Binding LoadTreeCommand}" />
            <TextBlock Text="Source — OneNote (notebooks, groups, sections)" FontWeight="SemiBold"
                       VerticalAlignment="Center" />
        </DockPanel>

        <!-- Left pane: everything above the page level. Pages are not shown. -->
        <TreeView Grid.Row="1" Grid.Column="0"
                  ItemsSource="{Binding Notebooks}"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <!-- Without this, screen readers announce the view-model's type name. -->
                    <Setter Property="AutomationProperties.Name" Value="{Binding Name}" />
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <!-- ResizeDirection must be explicit. With HorizontalAlignment=Stretch the default `Auto`
             resolves to Rows, and the splitter silently does nothing. -->
        <GridSplitter Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Width="6" Background="#20000000" Cursor="SizeWE" ShowsPreview="False" />

        <TextBlock Grid.Row="0" Grid.Column="2" Text="Destination — exactly one" FontWeight="SemiBold"
                   VerticalAlignment="Center" Margin="0,0,0,6" />

        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <RadioButton Grid.Row="0" x:Name="LocalRadio" GroupName="Dest" Content="Local folder"
                         IsChecked="True" Checked="OnLocalChecked" Margin="0,0,0,4" />

            <DockPanel Grid.Row="1" Margin="18,0,0,10"
                       IsEnabled="{Binding IsChecked, ElementName=LocalRadio}">
                <Button DockPanel.Dock="Right" Content="Browse…" Padding="10,3" Margin="6,0,0,0"
                        Command="{Binding BrowseLocalCommand}" />
                <TextBox Text="{Binding LocalPath, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>

            <RadioButton Grid.Row="2" x:Name="RemoteRadio" GroupName="Dest"
                         Content="SSH remote directory" Checked="OnRemoteChecked" Margin="0,0,0,4" />

            <Grid Grid.Row="3" Margin="18,0,0,0" IsEnabled="{Binding IsChecked, ElementName=RemoteRadio}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <Button DockPanel.Dock="Right" Content="Connect" Padding="10,3" Margin="6,0,0,0"
                            Command="{Binding ConnectCommand}" />
                    <ComboBox ItemsSource="{Binding Hosts}" SelectedItem="{Binding SelectedHost}" />
                </DockPanel>
                <TreeView Grid.Row="1" x:Name="RemoteTree" ItemsSource="{Binding RemoteRoots}"
                          SelectedItemChanged="OnRemoteDirSelected"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <Setter Property="AutomationProperties.Name" Value="{Binding Name}" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,10,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock TextTrimming="CharacterEllipsis">
                    <Run Text="{Binding SelectedSectionCount, Mode=OneWay}" FontWeight="Bold" />
                    <Run Text="section(s) selected  →" />
                    <Run Text="{Binding DestinationSummary, Mode=OneWay}" FontStyle="Italic" />
                </TextBlock>
                <ProgressBar Height="16" Margin="0,4,0,0" Minimum="0" Maximum="100"
                             Value="{Binding Progress, Mode=OneWay}" />
                <TextBlock Text="{Binding Status}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <Button Grid.Column="1" Content="Sync" Padding="26,7" Margin="12,0,6,0" FontWeight="SemiBold"
                    Command="{Binding SyncCommand}" />
            <Button Grid.Column="2" Content="Cancel" Padding="16,7" Command="{Binding CancelCommand}" />
        </Grid>

        <GridSplitter Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                      ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Height="6" Background="#20000000" Cursor="SizeNS" ShowsPreview="False" />

        <ListBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" ItemsSource="{Binding Log}"
                 FontFamily="Consolas" FontSize="11"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto" />
    </Grid>
</Window>
