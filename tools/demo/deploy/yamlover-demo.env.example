# Copy to ~/.config/yamlover-demo.env. Referenced by the user systemd unit
# (EnvironmentFile=%h/.config/yamlover-demo.env). Lives outside the deploy dir so a code
# redeploy (rsync --delete) never overwrites it.
#
# NOTE: systemd EnvironmentFile does NOT strip trailing `#` comments — an inline comment
# becomes part of the value. So every comment here is on its own line, never after a value.

# --- core ---
DEMO_DRIVER=docker
DEMO_BASE_URL=https://yamlover.inthemoon.net
HOST=127.0.0.1
PORT=8080

# --- lifecycle / limits ---
TTL_DAYS=3
MAX_DEMOS=50
# optional: also reclaim demos idle this long
# IDLE_HOURS=12

# --- persistence (kept under the deploy dir; rsync excludes .data/) ---
DB_PATH=/home/dims/Design/www/yamlover-demo/.data/demos.db

# --- docker driver (image published on Docker Hub by CI) ---
DEMO_IMAGE=dimskraft/yamlover-demo:latest
# set to 0 to skip the startup `docker pull` (e.g. a locally-built tag)
# DEMO_IMAGE_PULL=0
DOCKER_MEMORY=512m
DOCKER_CPUS=1

# --- email ---
# RESEND_API_KEY is NOT set here — it comes from /etc/resend.env via the unit's second
# EnvironmentFile (root-owned, group-readable by dims). EMAIL_FROM's domain must be
# verified in Resend (resend.com/domains: SPF/DKIM). Until then either point EMAIL_FROM at
# onboarding@resend.dev (delivers only to your own Resend account address) or set
# EMAIL_PROVIDER=console to log links to `journalctl --user -u yamlover-demo`.
EMAIL_PROVIDER=resend
EMAIL_FROM=yamlover demo <noreply@yamlover.inthemoon.net>
# EMAIL_PROVIDER=console

# --- abuse limits ---
# per-IP registration token bucket
REGISTER_PER_HOUR=3
# global cap on NEW demos per rolling 24h (bounds Resend sends + spawned instances)
REGISTER_PER_DAY=200

# --- captcha (Cloudflare Turnstile) ---
# Both unset → captcha disabled (the form still works). Set both to enable. The secret can
# also live in a root-only EnvironmentFile like the Resend key.
# TURNSTILE_SITE_KEY=0x4AAAAAAA...
# TURNSTILE_SECRET=0x4AAAAAAA...
