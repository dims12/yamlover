# Copy to /etc/yamlover-demo.env and fill in. Referenced by yamlover-demo.service.

# --- core ---
DEMO_DRIVER=docker
DEMO_BASE_URL=https://demo.example.com
HOST=127.0.0.1
PORT=8080

# --- lifecycle / limits ---
TTL_DAYS=3
MAX_DEMOS=50
# IDLE_HOURS=12          # optional: also reclaim demos idle this long

# --- persistence (under the systemd StateDirectory) ---
DB_PATH=/var/lib/yamlover-demo/demos.db

# --- docker driver ---
DEMO_IMAGE=dimskraft/yamlover-demo:latest   # published on Docker Hub by CI
# DEMO_IMAGE_PULL=0     # set to 0 to skip the startup `docker pull` (e.g. a locally-built tag)
DOCKER_MEMORY=512m
DOCKER_CPUS=1

# --- email (Resend) ---
EMAIL_PROVIDER=resend
EMAIL_FROM=yamlover demo <demo@demo.example.com>
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# --- abuse limits ---
REGISTER_PER_HOUR=3
