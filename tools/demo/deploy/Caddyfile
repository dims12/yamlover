# Caddy site block for the demo. bootstrap.sh APPENDS this to the host's existing
# /etc/caddy/Caddyfile (which already serves other sites — it is never clobbered).
# Reuses the wildcard *.inthemoon.net cert already on the box and reverse-proxies the
# whole app — the registration page AND every /demo/<hash>/ — to the demo server. Caddy
# flushes streamed responses, so the yamlover SSE stream (/api/events) passes through live.

yamlover.inthemoon.net {
	tls /etc/caddy/certs/inthemoon.net/fullchain.pem /etc/caddy/certs/inthemoon.net/privkey.pem
	encode gzip
	reverse_proxy 127.0.0.1:8080

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		-Server
		# No X-Frame-Options: yamlover renders file content in same-origin iframes.
	}
}
