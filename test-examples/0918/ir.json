              "edge": "contain",
              "value": {
                "kind": "scalar",
                "value": "Daily walks are not optional; they are how a dog reads the news of the neighbourhood.\nConsistency matters more than severity — the same word should always mean the same thing.\n",
                "array": false,
                "set": false,
                "anchors": [],
