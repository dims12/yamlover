                    }
                  },
                  {
                    "key": null,
                    "edge": "contain",
                    "value": {
                      "kind": "scalar",
                      "value": "@startgantt\nProject starts 2026-01-01\n[Settle in] lasts 3 days\n[House training] lasts 28 days\n[House training] starts at [Settle in]'s end\n[Socialisation] lasts 60 days\n[Socialisation] starts at [Settle in]'s end\n@endgantt\n",
