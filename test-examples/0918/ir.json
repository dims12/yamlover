            {
              "key": null,
              "edge": "contain",
              "value": {
                "kind": "scalar",
                "value": "Cycle a new tank for weeks before adding fish, so helpful bacteria can establish. Feed\nsparingly: uneaten food fouls the water faster than anything else.\n",
                "array": false,
                "set": false,
                "anchors": [],
                "entries": []
              }
            },
            {
              "key": null,
              "edge": "contain",
              "value": {
                "kind": "scalar",
                "value": "The bacteria you are waiting for run the **nitrogen cycle**, turning toxic waste into\nsomething far milder:\n",
                "array": false,
                "set": false,
                "anchors": [],
                "entries": []
              }
            },
            {
              "key": null,
              "edge": "contain",
              "value": {
                "kind": "scalar",
                "value": "@startuml\n[*] --> Ammonia : fish waste\nAmmonia --> Nitrite : Nitrosomonas\nNitrite --> Nitrate : Nitrobacter\nNitrate --> [*] : water change\n@enduml\n",
                "array": false,
                "set": false,
                "schema": {
                  "kind": "mapping",
                  "array": false,
