        }
      },
      {
        "key": null,
        "edge": "contain",
        "value": {
          "kind": "scalar",
          "value": "Inline math also handles the everyday: the area of a circle is $$A = \\pi r^2$$ and the\nquadratic formula $$x = \\frac{-b \\pm \\sqrt{b^2 - 4ac}}{2a}$$ both flow through the prose.\n",
          "array": false,
          "set": false,
          "anchors": [],
          "entries": []
        }
      },
