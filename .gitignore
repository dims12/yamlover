# JetBrains IDE
.idea/

# Claude Code local (personal) settings
.claude/settings.local.json

# Python
__pycache__/
*.py[cod]
.pytest_cache/

# Node
node_modules/

# Bundled server handler (generated at prepack — see tools/server/scripts/build.mjs)
tools/server/dist/

# Personal photo fixtures (carry EXIF GPS/device data — keep local only)
/examples/72-images/

# Playwright MCP scratch (screenshots, traces)
.playwright-mcp/

# yamlover engine SQLite cache (derived, rebuildable)
**/.yamlover/*.db
**/.yamlover/*.db-*

# Dev scratch at the repo root (created while serving the repo itself)
/.screenshots/
/bad/
/aaa.*

# JetBrains plugin build transients (Kotlin daemon sessions, platform updater lock)
tools/jetbrains-plugin/.kotlin/
tools/jetbrains-plugin/.intellijPlatform/
